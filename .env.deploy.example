# Copy this file to .env on the central machine and edit the values.

# PostgreSQL runs on the Docker host machine, not inside compose.
# On Linux Docker, host.docker.internal is provided by docker-compose extra_hosts.
DATABASE_URL=postgresql+psycopg2://postgres:CHANGE_ME@host.docker.internal:5432/leaderboard

# Frontend uses /api, then Next.js proxies requests to backend inside Docker.
NEXT_PUBLIC_API_BASE_URL=/api
INTERNAL_API_BASE_URL=http://backend:8001

# Large model uploads go directly from the browser to FastAPI.
# Leave empty to use http://CURRENT_HOST:8001.
NEXT_PUBLIC_UPLOAD_API_BASE_URL=
NEXT_PUBLIC_BACKEND_PORT=8001

# If users call backend directly, add the LAN origin here.
# Example: http://192.168.1.10:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

AUTO_PROCESS_SUBMISSIONS=true
AUTO_PROCESS_BRAND_PAYLOAD=data/process_payload_brand.example.json
AUTO_PROCESS_TYPE_PAYLOAD=data/process_payload_type.example.json

STORAGE_ROOT=storage/submissions
PREVIEW_ROOT=storage/previews
PREVIEW_SCALE=0.75

# CPU speed/accuracy knobs. Lower values are faster but may reduce accuracy.
EVAL_TARGET_FPS=10
YOLO_IMGSZ=416
YOLO_CONF=0.25

CELERY_TASK_TIME_LIMIT=7200
CELERY_TASK_SOFT_TIME_LIMIT=7000
